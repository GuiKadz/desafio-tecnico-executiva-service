# Used by docker-compose.yml. Copy to .env and adjust if needed:
#   cp .env.example .env
#   docker compose up

# --- Postgres ---
POSTGRES_USER=executiva
POSTGRES_PASSWORD=executiva_pass
POSTGRES_DB=executiva_contracts
POSTGRES_PORT=5432

# --- API ---
# Inside the compose network, the api reaches Postgres via the service name "db",
# not "localhost". apps/api/.env (used for local `pnpm dev` outside Docker) uses
# localhost instead — that's intentional, they're different network contexts.
DATABASE_URL=postgresql://executiva:executiva_pass@db:5432/executiva_contracts?schema=public
JWT_ACCESS_SECRET=replace_with_strong_secret_access
JWT_REFRESH_SECRET=replace_with_strong_secret_refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# --- Web ---
# Build-time + runtime URL the browser uses to reach the api.
NEXT_PUBLIC_API_URL=http://localhost:3001
